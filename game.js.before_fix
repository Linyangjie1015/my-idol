    ];
    
    var roleText = gameState.player.role === 'Trainee' ? '练习生' : '出道爱豆';
    var company = _getCompany(gameState.player.company);
    var timeLabel = '';
    if (gameState.player.role === 'Trainee') {
        var weekNum = Math.floor((gameState.gameDay - 1) / 7) + 1;
